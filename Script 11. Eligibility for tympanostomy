# ============================================================
korvat <- read_parquet("/media/volume/JaninaH/korva_historia") %>%
  filter(!is.na(KOODI))
dt <- read_parquet("/media/volume/JaninaH/avojahilmop_26_4.parquet")
#define sector with PALTU to match with real procedure, not according to prescriptions
dt <- dt%>%
  mutate(
    Sector = case_when(
      grepl("^95|^6", PALTU) ~ 2,#Jos paltu alkaa 95 tai 6 → 2
      TRUE ~ 1
    )
  )

setDT(korvat)
setDT(dt)

korvat[, visit_date := as.IDate(PVM)]

# ============================================================
# 2. TYMPANOSTOMY PROCEDURES
# Identify tympanostomy procedures using procedure codes 20 and 1019.
# Restricted to procedures performed between 2020–2022 (study period).
# Duplicate patient-date combinations are removed to retain one row
# per patient per procedure date.
# Tympanostomy procedures have been pre-filtered at data extraction;
# the grepl pattern serves as an additional verification step.
# ============================================================
putki <- dt[grepl("20|1019", TOIMP),
            .(FID, proc_date = as.IDate(PVM))]

putki <- putki[
  proc_date >= as.IDate("2020-01-01") &
  proc_date <= as.IDate("2022-12-31")
]

putki <- unique(putki, by = c("FID", "proc_date"))

# ============================================================
# 3. LINK PROCEDURE DATES TO ALL PRIOR VISITS
# Each tympanostomy is linked to all otitis media visits in the
# preceding 12 months + 30-day buffer (395 days) via a
# many-to-many merge on patient ID.
# Only visits occurring before or on the procedure date are retained.
# ============================================================
df <- merge(
  putki,
  korvat,
  by = "FID",
  allow.cartesian = TRUE   # expected: multiple visits per procedure
)

df <- df[
  visit_date <= proc_date &
  visit_date >= proc_date - 395
]

setorder(df, FID, proc_date, visit_date)

# ============================================================
# 4. DEFINE EPISODES (14-DAY WINDOW)
# Visits are grouped into episodes within each patient-procedure pair.
# A new episode begins when the gap from the current episode's start
# date exceeds 14 days. Episode numbering restarts for each procedure.
# ============================================================
df[, new_period := {
  period_id  <- 0L
  start_date <- as.IDate(NA)
  out        <- integer(.N)
  for (i in seq_len(.N)) {
    if (is.na(start_date) || visit_date[i] - start_date > 14) {
      period_id  <- period_id + 1L
      start_date <- visit_date[i]
    }
    out[i] <- period_id
  }
  out
}, by = .(FID, proc_date)]

# ============================================================
# 5. EPISODE START DATE
# Record the first visit date of each episode for use in
# calculating the time between episode onset and procedure date.
# ============================================================
df[, episode_start := min(visit_date), by = .(FID, proc_date, new_period)]

# ============================================================
# 6. COLLAPSE TO ONE ROW PER EPISODE
# Retain unique patient-procedure-episode combinations to avoid
# double-counting multiple visit rows within the same episode.
# Calculate the number of days between each episode start and
# the procedure date.
# ============================================================
episodes <- unique(df[, .(FID, proc_date, episode_start)])
episodes[, diff := as.numeric(proc_date - episode_start)]

# ============================================================
# 7. COUNT EPISODES WITHIN 6- AND 12-MONTH WINDOWS
# Count episodes whose start date falls within 180 days (6 months)
# or 365 days (12 months) of the procedure date, each extended by
# a 30-day buffer to allow for administrative coding delays.
# ============================================================
counts <- episodes[, .(
  n_6m  = sum(diff <= 213),   # 180 + 30 days
  n_12m = sum(diff <= 395)    # 365 + 30 days
), by = .(FID, proc_date)]

# ============================================================
# 8. APPLY RECURRENT AOM CRITERIA
# A patient is flagged as recurrent AOM (rAOM) if they had:
#   ≥3 episodes within 6 months, OR
#   ≥4 episodes within 12 months
# prior to the tympanostomy procedure date.
# ============================================================
counts[, recurrent_flag := as.integer(n_6m >= 3 | n_12m >= 4)]

# ============================================================
# 9. JOIN RECURRENT FLAG BACK TO FULL DATASET
# Merge episode counts and recurrent flag onto all visit rows.
# Patients with no matching count (no prior episodes in window)
# are assigned recurrent_flag = 0.
# ============================================================
df <- merge(df, counts, by = c("FID", "proc_date"), all.x = TRUE)
df[is.na(recurrent_flag), recurrent_flag := 0]

# ============================================================
# 10. FINAL PROCEDURE-LEVEL DATASET
# Collapse to one row per patient-procedure combination,
# retaining the recurrent AOM flag and episode counts.
# ============================================================
final <- unique(df[, .(
  FID,
  proc_date,
  recurrent_flag,
  n_6m,
  n_12m
)], by = c("FID", "proc_date"))

# ============================================================
# 11. DESCRIPTIVE CHECKS
# Verify distribution of recurrent flag and episode counts
# before proceeding to analysis.
# ============================================================
table(final$recurrent_flag)
summary(final$n_6m)
summary(final$n_12m)
