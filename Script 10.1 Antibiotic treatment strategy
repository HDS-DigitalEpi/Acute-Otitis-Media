library(tidyverse)

# =============================================================================
# BAYESIAN MULTINOMIAL MODEL — ANTIBIOTIC TREATMENT STRATEGY
# Outcome (ablk): Amoxicillin (ref) vs Amoxicillin-clavulanic vs Other
# Random intercept by patient (FID) to account for repeated visits
# =============================================================================

# Frequentist multinomial coefficients used as empirical basis for prior elicitation:
#
# Call: multinom(ablk ~ Sector + Sukupuoli + Ikalk + kieli + conditions +
#                erikoisala + sos + season + raom + dg, data = dt)
#
# Notable effects (log-OR scale):
#   Sector2:        +0.99 / +0.38  (private sector → more broad-spectrum)
#   erikoisalaENT:  +1.61 / +0.79  (ENT specialty → strongly more amox-clav)
#   raom:           +0.99 / +1.22  (recurrent AOM → broader antibiotics)
#   dgH66:          -0.19 / -0.59  (suppurative OM → less amox-clav / other)


# --- PRIOR ELICITATION -------------------------------------------------------
# Priors specified based on frequentist point estimates:
#   Strong informative  (sd = 1.0): large, consistent effects (Sector, ENT, raom)
#   Moderately informative (sd = 0.7): medium effects or clinically meaningful direction
#   Weakly informative  (sd = 0.5): small or uncertain effects

# Asymmetric priors flagged below:
#   erikoisalapediatrit → normal(0, 0.7)   # near-zero effect in frequentist model
#   Ikalk12-18          → normal(0, 0.7)   # modest age effect
#   erikoisalamuu       → normal(0, 0.7)   # small, uncertain
#   dgH66               → normal(-0.4, 0.7) # negative direction from frequentist model
#   kielimuu            → normal(0, 0.7)   # conservative, small effect


# --- 1. Extract coefficient names from prior skeleton -----------------------
p <- get_prior(
  ablk ~ Sector + Sukupuoli + Ikalk + kieli + conditions +
    erikoisala + sos + season + raom + dg +
    (1 || FID),       # || = no correlation between random effects (faster)
  family = categorical(),
  data = dt
)

coef_names <- unique(p$coef[p$class == "b" & p$coef != ""])


# --- 2. Define prior structure ----------------------------------------------

# Strong priors: large effects observed in frequentist model, mean ≠ 0
strong_means <- c(
  "Sector2"      = 1.0,   # private sector
  "erikoisalaENT" = 1.6,  # ENT specialty
  "raom1"        = 1.0    # recurrent AOM history
)

# Medium priors: asymmetric (negative direction from frequentist model)
medium_means <- c(
  "dgH66" = -0.4   # suppurative OM diagnosis → less broad-spectrum
)

# Medium priors: symmetric around zero (modest or uncertain effects)
medium_vars <- c(
  "erikoisalapediatrit",
  "Ikalk12-18",
  "erikoisalamuu",
  "conditions1",
  names(medium_means)
)

# Weak priors: all remaining covariates (small/uncertain effects)
weak_vars <- setdiff(coef_names, c(names(strong_means), medium_vars))


# --- 3. Intercept priors ----------------------------------------------------
# Centred on frequentist intercept estimates; wide SD to allow data to dominate
priors <- c(
  prior(normal(-1.2, 1.5), class = "Intercept", dpar = "muAmoxicillinclavulanic"),
  prior(normal(-1.8, 1.5), class = "Intercept", dpar = "muother")
)


# --- 4. Loop over all coefficients and assign priors -----------------------
# Same prior applied to both outcome categories (amox-clav and other)
for (v in coef_names) {
  
  if (v %in% names(strong_means)) {
    mu <- strong_means[v]; sd <- 1
    
  } else if (v %in% names(medium_means)) {
    mu <- medium_means[v]; sd <- 0.7
    
  } else if (v %in% medium_vars) {
    mu <- 0; sd <- 0.7
    
  } else {
    mu <- 0; sd <- 0.5   # weak / residual covariates
  }
  
  prior_text <- paste0("normal(", mu, ",", sd, ")")
  
  priors <- c(priors,
              prior_string(prior_text, class = "b", coef = v,
                           dpar = "muAmoxicillinclavulanic"),
              prior_string(prior_text, class = "b", coef = v,
                           dpar = "muother")
  )
}


# --- 5. Adjusted model formula ----------------------------------------------
# QR decomposition improves sampling efficiency for correlated predictors
form <- bf(
  ablk ~ Sector + Ikalk + Sukupuoli + kieli + sos + erikoisala +
    dg + conditions + season + raom + (1 || FID),
  decomp = "QR"
)

dt <- as.data.frame(dt)
set_cmdstan_path("/home/hansasja/Desktop/shared-directory/sd-tools/apps/R/lib/cmdstan-2.37.0")
set.seed(1)   # reproducibility

# --- 6. Fit adjusted model --------------------------------------------------
fit <- brm(
  formula = form,
  data    = dt,
  family  = categorical(),   # unordered 3-category outcome
  chains  = 4,
  cores   = 4,
  threads = threading(3),    # within-chain parallelisation (4 chains × 3 threads = 12 cores)
  iter    = 1000,
  warmup  = 500,
  save_warmup = FALSE,
  prior   = priors,
  backend = "cmdstanr",
  control = list(adapt_delta = 0.95, max_treedepth = 12),
  save_pars = save_pars(
    group  = FALSE,   # exclude per-patient random effect draws (reduces file size)
    latent = FALSE,
    all    = FALSE
  )
)

saveRDS(fit, file = "brms_adj_priors_fit.rds")


# --- 7. Extract fixed effects and convert to odds ratios -------------------
fe <- fixef(fit, probs = c(0.025, 0.975)) %>%
  as.data.frame() %>%
  rownames_to_column("term") %>%
  as_tibble()

or_tbl <- fe %>%
  transmute(
    term,
    OR      = exp(Estimate),   # posterior median OR
    CI_low  = exp(Q2.5),       # 95% credible interval lower bound
    CI_high = exp(Q97.5)       # 95% credible interval upper bound
  )

View(or_tbl)


# =============================================================================
# CRUDE MODEL — Sector only, same random structure
# Intercept priors centred on frequentist crude estimates:
#   Amox-clav intercept: -2.26; Other intercept: -1.87
#   Sector2 log-OR:      +1.77 (amox-clav), +0.50 (other)
# =============================================================================

priors_crude <- c(
  prior(normal(-2.3, 1.5), class = "Intercept", dpar = "muAmoxicillinclavulanic"),
  prior(normal(-1.9, 1.5), class = "Intercept", dpar = "muother"),
  prior(normal(1.8, 1),    class = "b", coef = "Sector2", dpar = "muAmoxicillinclavulanic"),
  prior(normal(0.5, 1),    class = "b", coef = "Sector2", dpar = "muother")
  # Random effect SD: default half-Student-t(3, 0, 2.5) used
)

form <- bf(ablk ~ Sector + (1 || FID), decomp = "QR")

# --- 8. Fit crude model -----------------------------------------------------
fit <- brm(
  formula = form,
  data    = dt,
  family  = categorical(),
  chains  = 4,
  cores   = 4,
  threads = threading(3),
  iter    = 1000,
  warmup  = 500,
  save_warmup = FALSE,
  prior   = priors_crude,
  backend = "cmdstanr",
  control = list(adapt_delta = 0.95, max_treedepth = 12),
  save_pars = save_pars(group = FALSE, latent = FALSE, all = FALSE)
)

saveRDS(fit, file = "brms_crude_priors_fit.rds")


# --- 9. Extract crude ORs --------------------------------------------------
fe <- fixef(fit, probs = c(0.025, 0.975)) %>%
  as.data.frame() %>%
  rownames_to_column("term") %>%
  as_tibble()

or_tbl <- fe %>%
  transmute(
    term,
    OR      = exp(Estimate),
    CI_low  = exp(Q2.5),
    CI_high = exp(Q97.5)
  )

View(or_tbl)

# =========================================================
# DESCRIPTIVES
# =========================================================

dt %>%
  group_by(Sector) %>%
  summarise(
    n_total = n(),
    n_abp = sum(abp == 1, na.rm = TRUE),
    pct_abp = 100 * n_abp / n_total
  )

