# Add calendar year of visit for merging with annual socioeconomic status
df <- df %>% mutate(Year = year(PVM))

# Retain the last recorded socioeconomic status per person per year
# to avoid duplicate rows when merging
status_df <- sose %>%
  group_by(vuosi, FID) %>%
  summarise(sose = last(sose), .groups = "drop")

# Merge annual socioeconomic status into main dataset
yhd <- df %>%
  left_join(status_df, by = c("FID", "Year" = "vuosi"))

# Extract the first digit of the socioeconomic code (broad category)
yhd$sos <- substr(as.character(yhd$sose), 1, 1)
table(yhd$sos)

# Reclassify into simplified occupational categories:
#   1–2 = employed (workers); 3 = upper-level employees;
#   4–5 = employed (self-employed/farmers); 6 = students;
#   7 = retired; 8 = unemployed; 9 = unknown
yhd$sos <- factor(yhd$sos,
                  levels = c("1", "2", "3", "4", "5", "6", "7", "8", "9"),
                  labels = c("toissa", "toissa", "ylemmat", "toissa", "toissa",
                             "opiskelijat", "toissa", "tyottomat", "tuntematon"))

# Classify native language as domestic (Finnish or Swedish) vs. other
yhd <- yhd %>%
  mutate(kieli = case_when(
    str_detect(kieli, regex("fi|sv", ignore_case = TRUE))  ~ "kotim",
    !str_detect(kieli, regex("fi|sv", ignore_case = TRUE)) ~ "muu"
  ))
table(yhd$kieli)


