  filter(AVOHILMOID %in% id)

Ahs22_2 <- read_delim("/media/volume/Data_20260319//THL//FD_2698_THL2023_2698_AH_22_2.csv",
                      delim = ";", col_types = cols(.default = "c"),
                      locale = locale(encoding = "UTF-8")) %>%
  select(FID, AVOHILMOID, KAYNTI_LOPPUI) %>%
  filter(AVOHILMOID %in% id)

ah1722 <- bind_rows(Ahs16, Ahs17, Ahs18, Ahs19, Ahs20, Ahs21_1, Ahs21_2, Ahs22_1, Ahs22_2)
ah1722$AVOHILMOID <- as.character(ah1722$AVOHILMOID)

# Join long-term OM diagnosis codes onto visit data; remove non-diagnostic columns
avop <- left_join(ah1722, p12, by = "AVOHILMOID")
avop <- avop[, -c(3, 5)]                   # Remove provider and physician hash columns
avop <- avop %>% filter(!is.na(ICD10))     # Retain only rows with a diagnosis code

# Harmonise column names
colnames(avop)[4] <- "KOODI"
colnames(avop)[2] <- "FID"
colnames(avop)[1] <- "AVOTAIHILMOID"
colnames(avop)[3] <- "PVM"
avop$PVM <- as.Date(as.character(avop$PVM), format = "%d.%m.%Y %H:%M")

# Combine all otitis media history sources (AvoHILMO visit reasons, HILMO,
# and AvoHILMO long-term diagnoses) and retain only H65–H67 diagnoses
korvat <- bind_rows(avof, hilf, avop)
korvat <- korvat %>% filter(grepl("^H67|^H66|^H65", KOODI, ignore.case = TRUE))
korvat <- korvat %>% filter(!is.na(KOODI))

korvat %>% write_parquet("/media/volume/JaninaH/korva_historia")
korvat <- read_parquet("/media/volume/JaninaH/korva_historia")


# --- 15.3 Define otitis media episodes using a 30-day grouping window --------
#
#          Multiple visits within 30 days of the first visit in a cluster are
#          counted as a single episode; a new episode begins when the gap
#          from the first visit of the current cluster exceeds 30 days.

library(data.table)

df <- korvat %>%
  mutate(date_only = as.Date(PVM)) %>%
  arrange(FID, date_only) %>%
  group_by(FID) %>%
  mutate(
    new_period = {
      period_id  <- 0L          # Initialise episode counter
      start_date <- NA          # Track start date of current episode
      result     <- integer(n())

      for (i in seq_along(date_only)) {
        # Start a new episode if no episode yet, or gap from episode start > 30 days
        if (is.na(start_date) || as.numeric(date_only[i] - start_date) > 30) {
          period_id  <- period_id + 1L
          start_date <- date_only[i]
        }
        result[i] <- period_id  # Assign current episode number to this row
      }
      result
    }
  ) %>%
  ungroup()


# --- 15.4 Calculate visit order within episode and count repeated episodes ---

df <- df %>%
  group_by(FID, new_period) %>%
  mutate(
    # Rank visits within each episode chronologically
    visit_order_in_period = dense_rank(date_only),

    # Count the number of additional (repeat) visits within the episode,
    # recorded only on the first visit row; subsequent rows receive NA
    repeat_count = if_else(
      visit_order_in_period == 1,
      as.integer(n_distinct(date_only) - 1),
      NA_integer_
    )
  ) %>%
  ungroup()

# Binary flag: 0 = first visit in episode, 1 = repeat visit within episode
df$is_repetative <- ifelse(grepl("1", df$visit_order_in_period), 0, 1)


# --- 15.5 Count prior OM episodes within rolling 6- and 12-month windows -----
#
#          Visits are first collapsed to one row per patient-date (episode level)
#          to avoid double-counting multiple diagnosis rows from the same visit.

setDT(df)
df[, PVM := as.Date(PVM)]

# Aggregate to one row per patient per date (episode-level)
visits <- df[, .(new_period = first(new_period)), by = .(FID, PVM)]
setorder(visits, FID, PVM)

# For each episode date, count how many prior episode dates fall within
# the preceding 180 days (6 months) and 365 days (12 months)
visits[, count_6m := {
  sapply(seq_len(.N), function(i) sum(PVM[1:(i-1)] >= PVM[i] - 180))
}, by = FID]

visits[, count_12m := {
  sapply(seq_len(.N), function(i) sum(PVM[1:(i-1)] >= PVM[i] - 365))
}, by = FID]

# Apply clinical rAOM criteria:
#   ≥3 episodes within 6 months OR ≥4 episodes within 12 months
visits[, recurrent := fifelse(count_6m >= 3 | count_12m >= 4, 1, 0)]

# Join recurrent flag back to full dataset so all rows from the same visit
# share the same recurrent status
df <- visits[df, on = .(FID, PVM)]


# --- 15.6 Flag rAOM status at each study visit using a 365-day look-back -----
#
#          raom = 1 if the patient met rAOM criteria at any point in the
#          preceding year, capturing active recurrent disease at the time
#          of the index otitis media visit.

df[, PVM := as.IDate(PVM)]

lookback_days <- 365L

# Record the date of each episode that met rAOM criteria
df[, rec_date := fifelse(recurrent == 1L, PVM, as.IDate(NA))]

# Sort chronologically within each patient
setorder(df, FID, PVM)

# Propagate the most recent rAOM date forward within each patient
# using last-observation-carried-forward (LOCF), so that subsequent
# visits "inherit" awareness of the most recent rAOM episode
df[, anchor := nafill(rec_date, type = "locf"), by = FID]

# Set raom = 1 if an rAOM anchor date exists and the current visit is
# within 365 days of that anchor — i.e., the patient is in an active
# rAOM phase at the time of the current visit
df[, raom := as.integer(!is.na(anchor) & as.integer(PVM - anchor) <= lookback_days)]

# Save final dataset with rAOM flag
df %>% write_parquet("/media/volume/JaninaH/korva_historia")
