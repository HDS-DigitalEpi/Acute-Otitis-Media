# Convert qualification date to Date format
erik$Suorituspvm <- as.Date(erik$Suorituspvm, format = "%d.%m.%Y")

# Merge qualification data with main dataset:
# retain only qualifications obtained before the visit date,
# and keep only the most recent valid qualification per prescriber per visit
df_final <- yhd %>%
  left_join(erik, by = c("FD_HASH_Rekisterointinro" = "FD_HASH_Rekisterointinumero")) %>%
  mutate(valid = if_else(Suorituspvm <= PVM, TRUE, FALSE)) %>%
  group_by(FID, PVM, FD_HASH_Rekisterointinro, ATC_CODE, Sector, ab, TOIMP) %>%
  arrange(desc(valid), desc(Suorituspvm)) %>%
  slice(1) %>%
  ungroup() %>%
  mutate(erikoisala = if_else(valid, Tutkinto, NA_character_))

# Classify physicians into specialty categories relevant to otitis media care:
#   - Paediatricians (lasten- = paediatric in Finnish)
#   - ENT specialists (korva- = ear in Finnish)
#   - General practitioners (yleis- = general in Finnish)
#   - Non-specialists (no specialist title)
#   - Other specialists
dt <- df_final %>%
  mutate(erikoisala = case_when(
    str_detect(Tutkinto, regex("lasten", ignore_case = TRUE))                                  ~ "pediatrit",
    str_detect(Tutkinto, regex("korva",  ignore_case = TRUE))                                  ~ "ENT",
    str_detect(Tutkinto, regex("yleis",  ignore_case = TRUE))                                  ~ "GP",
    !str_detect(Tutkinto, regex("erikoislääkäri|erikoishammaslääkäri", ignore_case = TRUE))   ~ "ei",
    str_detect(Tutkinto, regex("erikoislääkäri|erikoishammaslääkäri",  ignore_case = TRUE))   ~ "muu",
    TRUE ~ NA_character_
  ))

