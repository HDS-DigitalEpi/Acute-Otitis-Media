# =========================================================
# ANTIBIOTIC TREATMENT STRATEGY
# =========================================================

dt <- read_parquet("/JaninaH/abdt_worstcase_doctor_sector.parquet")

# =========================================================
# CLEANING
# =========================================================

dt <- dt %>%
  mutate(conditions = if_else(is.na(conditions), 0, conditions))

dt <- dt %>%
  mutate(sos = if_else(sos == "elakelaiset", "toissa", sos))

dt <- dt %>%
  mutate(erikoisala = if_else(is.na(erikoisala), "ei", erikoisala))

dt <- dt %>%
  mutate(sos = if_else(is.na(sos), "tuntematon", sos))

# =========================================================
# FACTOR CONVERSION
# =========================================================

dt$ablk   <- factor(dt$ablk)
dt$Sector <- factor(dt$Sector)
dt$FID    <- factor(dt$FID)   # random intercept
dt$season <- factor(dt$season)
dt$sos <- factor(dt$sos)
dt$kieli <- factor(dt$kieli)
dt$conditions <- factor(dt$conditions)
dt$erikoisala <- factor(dt$erikoisala)
dt$Ikalk <- factor(dt$Ikalk)
dt$dg <- factor(dt$dg)
dt$Sukupuoli <- factor(dt$Sukupuoli)
dt$raom <- factor(dt$raom)

# =========================================================
# DATA FILTERING
# =========================================================

# only index visits
dt <- dt %>% filter(is_repetative == 0)

# only visits with antibiotic prescription
dt <- dt %>% filter(abp == 1)


dt <- dt[dt$Sector != 3, ]



# =========================================================


# =========================================================
# MODEL SPECIFICATION
# =========================================================

# crude model
form <- bf(ablk ~ Sector + (1 || FID))

# =========================================================
# FULL MODEL 
# =========================================================
#covariates: sector, age, sex, native language, occupational status of a parent, physician specialty,
#season, occurence of selected chronical conditions and recurrent AOM within a year before visit

form <- bf(
  ablk ~ Sector + Ikalk + Sukupuoli + kieli + sos +
    erikoisala + dg + conditions + season + raom +
    (1 || FID)
)

# =========================================================
# MODEL FITTING
# =========================================================

fit <- brm(
  formula = form,
  data = dt,
  family = categorical(),  
  chains = 4,
  cores  = 4,
  threadind = 3, #12 cores are used simultanously
  priors = prior,
  iter   = 1000,
  warmup = 500,
  backend = "cmdstanr",  
  control = list(
    adapt_delta = 0.95,
    max_treedepth = 12
  ),
  
  save_pars = save_pars(
    group = FALSE,   # ei random effects outputtia
    latent = FALSE,
    all = FALSE
  )
)

# =========================================================
# SAVE MODEL
# =========================================================

saveRDS(fit, file = "brms_adj_fit.rds")

# =========================================================
# RESULTS: ODDS RATIOS
# =========================================================

fe <- fixef(fit, probs = c(0.025, 0.975)) %>%
  as.data.frame() %>%
  rownames_to_column("term") %>%
  as_tibble()

or_tbl <- fe %>%
  transmute(
    term,
    OR      = exp(Estimate),
    CI_low  = exp(Q2.5),
    CI_high = exp(Q97.5)
  )

View(or_tbl)

summary(fit)
