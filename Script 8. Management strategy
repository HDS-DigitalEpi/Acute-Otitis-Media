# =========================================================
# MANAGEMENT STRATEGY
# =========================================================

dt <- read_parquet("/JaninaH/strategydt_worstcase_doctor_sector.parquet")

# --- Cleaning ---na values treated as zero
dt <- dt %>%
  mutate(conditions = if_else(is.na(conditions), 0, conditions))

# Retired ("elakelaiset") are combined with other forms of employment ("toissa)(due small sample size)
dt <- dt %>%
  mutate(sos = if_else(sos == "elakelaiset", "toissa", sos))

# If specialty is NA--> coded as no specialty 
dt <- dt %>%
  mutate(erikoisala = if_else(is.na(erikoisala), "ei", erikoisala))

# If occupational status is NA--> coded as "unknown"
dt <- dt %>%
  mutate(sos = if_else(is.na(sos), "tuntematon", sos))

# =========================================================
# CRUDE MODEL
# =========================================================

model <- glmmTMB(
  abp ~ Sector + (1|FID),
  data = dt,
  family = binomial(link = "logit")
)
summary(model)
exp(confint(model))


# =========================================================
# ADJUSTED MODEL
# =========================================================

model <- glmmTMB(
  abp ~ Sector + Ikalk + Sukupuoli + kieli + sos +
    erikoisala + season + raom + conditions + dg + (1 | FID),
  data = dt,
  family = binomial(link = "logit")
)

summary(model)
exp(confint(model))


# =========================================================
# DESCRIPTIVES
# =========================================================

dt %>%
  group_by(Sector) %>%
  summarise(
    n_total = n(),
    n_abp = sum(abp == 1, na.rm = TRUE),
    pct_abp = 100 * n_abp / n_total
  )

# =========================================================
# DUPLICATE VISITS CHECK 
# =========================================================

counts <- dt %>%
  group_by(FID, PVM, Sector) %>%
  summarise(
    n_rows = n(),
    n_fd_hash = n_distinct(FD_HASH_Rekisterointinro)
  ) %>%
  filter(n_fd_hash > 1)



